  "models": [
    {
      "id": "accordion",
      "fields": [
        {
          "component": "tab",
          "label": "Overview",
          "name": "overview"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "blockHeading",
          "value": "",
          "label": "Block Heading",
          "description": "Provide heading text for this set of accordion items."
        },
        {
          "component": "boolean",
          "name": "classes_allowMultipleOpen",
          "value": false,
          "valueType": "boolean",
          "label": "Allow multiple Accordion Items open",
          "description": "By default when a user opens an Accordion Item the previously opened Accordion Item will be closed. Enable this to allow more than one Accordion Item open at a time"
        },
        {
          "component": "boolean",
          "name": "classes_showExpandCollapseAll",
          "value": false,
          "valueType": "boolean",
          "label": "Show Expand/Collapse all button",
          "description": "Show a button that allows the user to expand or collapse all Accordion Items with a single click."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "expandAllText",
          "value": "Expand All",
          "label": "Expand All text",
          "condition": {
            "===": [
              { "var": "classes_showExpandCollapseAll" },
              true
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "collapseAllText",
          "value": "Collapse All",
          "label": "Collapse All text",
          "condition": {
            "===": [
              { "var": "classes_showExpandCollapseAll" },
              true
            ]
          }
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "classes_iconType",
          "value": "accordion-icon-font",
          "label": "Icon Type",
          "description": "Choose whether accordion controls use icon fonts or images.",
          "options": [
            {
              "name": "Icon Font",
              "value": "accordion-icon-font"
            },
            {
              "name": "Image",
              "value": "accordion-icon-image"
            }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "expandAllIcon",
          "value": "plus",
          "label": "Expand All Font Icon",
          "condition": {
            "and": [
              {
                "===": [
                  { "var": "classes_showExpandCollapseAll" },
                  true
                ]
              },
              {
                "===": [
                  { "var": "classes_iconType" },
                  "accordion-icon-font"
                ]
              }
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "collapseAllIcon",
          "value": "minus",
          "label": "Collapse All Font Icon",
          "condition": {
            "and": [
              {
                "===": [
                  { "var": "classes_showExpandCollapseAll" },
                  true
                ]
              },
              {
                "===": [
                  { "var": "classes_iconType" },
                  "accordion-icon-font"
                ]
              }
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "expandIcon",
          "value": "plus",
          "label": "Expand Font Icon",
          "condition": {
            "===": [
              { "var": "classes_iconType" },
              "accordion-icon-font"
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "collapseIcon",
          "value": "minus",
          "label": "Collapse Font Icon",
          "condition": {
            "===": [
              { "var": "classes_iconType" },
              "accordion-icon-font"
            ]
          }
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "expandAllIconImage",
          "label": "Expand All Image Icon",
          "multi": false,
          "condition": {
            "and": [
              {
                "===": [
                  { "var": "classes_showExpandCollapseAll" },
                  true
                ]
              },
              {
                "===": [
                  { "var": "classes_iconType" },
                  "accordion-icon-image"
                ]
              }
            ]
          }
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "collapseAllIconImage",
          "label": "Collapse All Image Icon",
          "multi": false,
          "condition": {
            "and": [
              {
                "===": [
                  { "var": "classes_showExpandCollapseAll" },
                  true
                ]
              },
              {
                "===": [
                  { "var": "classes_iconType" },
                  "accordion-icon-image"
                ]
              }
            ]
          }
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "expandIconImage",
          "label": "Expand Image Icon",
          "multi": false,
          "condition": {
            "===": [
              { "var": "classes_iconType" },
              "accordion-icon-image"
            ]
          }
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "collapseIconImage",
          "label": "Collapse Image Icon",
          "multi": false,
          "condition": {
            "===": [
              { "var": "classes_iconType" },
              "accordion-icon-image"
            ]
          }

        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Story Card",
              "model": "story-card",
              "storyCardType": "cardInfo",
              "hidePublicationDate": false,
              "hideReadTime": false,
              "hideTitle": false,
              "hideDescription": false,
              "hideImage": false,
              "page": "",
              "openInNewTab": false,
              "imagePreset": "",
              "imageModifiers": "",
              "analyticsInteractionId": "",

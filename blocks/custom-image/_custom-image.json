{
  "definitions": [
    {
      "title": "Custom Image",
      "id": "custom-image",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Custom Image",
              "model": "custom-image",
              "imageAlt": "",
              "getAltFromDAM": false,
              "imageIsDecorative": false,
              "caption": "",
              "getCaptionFromDAM": false,
              "displayCaptionBelowImage": false,
              "enableLink": false,
              "target": "",
              "clickBehavior": "_self",
              "modalPanelId": "",
              "enableWarnOnLeave": false,
              "warnOnLeavePath": "",
              "linkAriaLabel": "",
              "analyticsInteractionId": "",
              "blockId": "",
              "classes_commonCustomClass": "",
              "language": "none"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "custom-image",
      "fields": [
        {
          "component": "tab",
          "label": "Overview",
          "name": "overview"
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "valueType": "string",
          "name": "image",
          "label": "Image",
          "configUrl": "/content/dam/config/image/asset-selector.json",
          "multi": false
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "imageMimeType"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "value": "",
          "label": "Alternative Text",
          "description": "Provide alternative text for your image",
          "required": true
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "getAltFromDAM",
          "value": false,
          "label": "Get alternative text from DAM"
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "imageIsDecorative",
          "value": false,
          "label": "Image is decorative"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "caption",
          "value": "",
          "label": "Caption",
          "description": "Text displayed as a caption for the image"
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "getCaptionFromDAM",
          "value": false,
          "label": "Get caption from DAM"
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "displayCaptionBelowImage",
          "value": false,
          "label": "Enable caption as text under image"
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "enableLink",
          "value": false,
          "label": "Enable Link",
          "description": "Enable linking from the image to another target"
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "target",
          "value": "",
          "label": "Target",
          "description": "Provide your target path or URL",
          "condition": {
            "===": [{ "var": "enableLink" }, true]
          }
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "clickBehavior",
          "value": "_self",
          "label": "Click Behavior",
          "description": "Select the behavior of this button",
          "condition": {
            "===": [{ "var": "enableLink" }, true]
          },
          "options": [
            { "name": "Same Tab", "value": "_self" },
            { "name": "New Tab", "value": "_blank" },
            { "name": "Modal", "value": "modal" },
            { "name": "Hidden Panel", "value": "hidden-panel" }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "modalPanelId",
          "value": "",
          "label": "Modal/Hidden Panel ID",
          "description": "ID of the modal or hidden panel to trigger",
          "condition": {
            "and": [
              { "===": [{ "var": "enableLink" }, true] },
              {
                "or": [
                  { "===": [{ "var": "clickBehavior" }, "modal"] },
                  { "===": [{ "var": "clickBehavior" }, "hidden-panel"] }
                ]
              }
            ]
          }
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "enableWarnOnLeave",
          "value": false,
          "label": "Enable Warn on Leave Modal",
          "description": "Show a warning modal when the user navigates away",
          "condition": {
            "===": [{ "var": "enableLink" }, true]
          }
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "warnOnLeavePath",
          "value": "",
          "label": "Warn on leave modal path",
          "condition": {
            "and": [
              { "===": [{ "var": "enableLink" }, true] },
              { "===": [{ "var": "enableWarnOnLeave" }, true] }
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "linkAriaLabel",
          "value": "",
          "label": "Link Aria Label",
          "description": "Provide an aria-label for the image target link"
        },
        {
          "component": "tab",
          "label": "Styles",
          "name": "styles"
        },
        {
          "component": "ngaem:dynamic-picklist",
          "name": "classes_customDynamicClass",
          "value": "",
          "label": "Select Block Styles",
          "valueType": "string",
          "sourceAEMNodeName": "image-picklist-config",
          "valueSeperator": ","
        },
        {
          "...": "../../models/_common-properties.json#/common-prop"
        }
      ]
    }
  ],
  "filters": []
}

{
  "definitions": [
    {
      "title": "Custom Image",
      "id": "custom-image",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Custom Image",
              "model": "custom-image",
              "presetType": "",
              "imagePreset": "",
              "rendition": "",
              "imageModifiers": "",
              "imageAlt": "",
              "getAltFromDAM": false,
              "imageIsDecorative": false,
              "caption": "",
              "getCaptionFromDAM": false,
              "displayCaptionBelowImage": false,
              "enableLink": false,
              "target": "",
              "clickBehavior": "_self",
              "modalPanelId": "",
              "enableWarnOnLeave": false,
              "warnOnLeavePath": "",
              "linkAriaLabel": "",
              "analyticsInteractionId": "",
              "blockId": "id:",
              "classes_commonCustomClass": "",
              "language": "lang:none"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "custom-image",
      "fields": [
        {
          "component": "tab",
          "label": "Overview",
          "name": "overview"
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "valueType": "string",
          "name": "image",
          "label": "Image",
          "configUrl": "/content/dam/corporate/asset-selector.json"
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "imageMimeType"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Alt",
          "value": ""
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "getAltFromDAM",
          "value": false,
          "label": "Get alternative text from DAM"
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "imageIsDecorative",
          "value": false,
          "label": "Image is decorative"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "caption",
          "value": "",
          "label": "Caption",
          "description": "Text displayed as a caption for the image"
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "getCaptionFromDAM",
          "value": false,
          "label": "Get caption from DAM"
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "displayCaptionBelowImage",
          "value": false,
          "label": "Enable caption as text under image"
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "enableLink",
          "value": false,
          "label": "Enable Link",
          "description": "Enable linking from the image to another target"
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "target",
          "value": "",
          "label": "Target",
          "description": "Provide your target path or URL",
          "condition": {
            "===": [{ "var": "enableLink" }, true]
          }
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "clickBehavior",
          "value": "_self",
          "label": "Click Behavior",
          "description": "Select the behavior of this button",
          "condition": {
            "===": [{ "var": "enableLink" }, true]
          },
          "options": [
            { "name": "Same Tab",     "value": "_self" },
            { "name": "New Tab",      "value": "_blank" },
            { "name": "Modal",        "value": "modal" },
            { "name": "Hidden Panel", "value": "hidden-panel" }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "modalPanelId",
          "value": "",
          "label": "Modal/Hidden Panel ID",
          "description": "ID of the modal or hidden panel to trigger",
          "condition": {
            "and": [
              { "===": [{ "var": "enableLink" }, true] },
              {
                "or": [
                  { "===": [{ "var": "clickBehavior" }, "modal"] },
                  { "===": [{ "var": "clickBehavior" }, "hidden-panel"] }
                ]
              }
            ]
          }
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "enableWarnOnLeave",
          "value": false,
          "label": "Enable Warn on Leave Modal",
          "description": "Show a warning modal when the user navigates away",
          "condition": {
            "===": [{ "var": "enableLink" }, true]
          }
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "warnOnLeavePath",
          "value": "",
          "label": "Warn on leave modal path",
          "condition": {
            "and": [
              { "===": [{ "var": "enableLink" }, true] },
              { "===": [{ "var": "enableWarnOnLeave" }, true] }
            ]
          }
        },
        {
          "component": "tab",
          "label": "Accessibility",
          "name": "accessibility"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "linkAriaLabel",
          "value": "",
          "label": "Link Aria Label",
          "description": "Provide an aria-label for the image target link"
        },
        {
          "component": "tab",
          "label": "Analytics",
          "name": "analytics"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "analyticsInteractionId",
          "value": "",
          "label": "Analytics Interaction ID",
          "description": "Analytics interaction identifier for tracking"
        },
        {
          "component": "tab",
          "label": "Styles",
          "name": "styles"
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "classes_shape",
          "label": "Shape",
          "options": [
            { "name": "Default", "value": "" },
            { "name": "Circle", "value": "circle" },
            { "name": "Logo", "value": "logo" }
          ]
        },
        {
          "...": "../../models/_common-properties.json#/common-prop"
        }
      ]
    }
  ],
  "filters": []
}

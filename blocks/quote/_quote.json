{
  "definitions": [
    {
      "title": "Quote",
      "id": "quote",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Quote",
              "model": "quote",
              "id": "",
              "customClass": "",
              "quoteVariant": "basic",
              "backgroundImageAlt": "",
              "classes_theme": "quote-none",
              "classes_contentAlignment": "quote-align-none",
              "classes_contentWidth": "quote-content-col-none",
              "language": "none",
              "blockId": ""
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "quote",
      "fields": [
        {
          "component": "tab",
          "label": "Overview",
          "name": "overview"
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "quoteVariant",
          "value": "basic",
          "label": "Quote Type",
          "required": true,
          "options": [
            {
              "name": "Basic",
              "value": "basic"
            },
            {
              "name": "Content Fragment",
              "value": "content-fragment"
            }
          ]
        },
        {
          "component": "richtext",
          "valueType": "string",
          "name": "quotation",
          "value": "",
          "label": "Quote Text",
          "description": "Provide the quote",
          "condition": {
            "in": [
              {
                "var": "quoteVariant"
              },
              ["basic"]
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "attributionName",
          "value": "",
          "label": "Attribution Name",
          "description": "Provide the name of the author",
          "condition": {
            "in": [
              {
                "var": "quoteVariant"
              },
              ["basic"]
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "attributionRole",
          "value": "",
          "label": "Attribution Title",
          "description": "Provide the title of the author",
          "condition": {
            "in": [
              {
                "var": "quoteVariant"
              },
              ["basic"]
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "valueType": "string",
          "name": "attributionImage",
          "label": "Attribution Image",
          "description": "Select an image of the author",
          "configUrl": "/content/dam/config/image/asset-selector.json",
          "multi": false,
          "condition": {
            "in": [
              {
                "var": "quoteVariant"
              },
              ["basic"]
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "attributionImageMimeType"
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "quoteFragment",
          "label": "Quote Fragment",
          "description": "Select a quote from the Content Fragments",
          "condition": {
            "in": [
              {
                "var": "quoteVariant"
              },
              ["content-fragment"]
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "valueType": "string",
          "name": "backgroundImage",
          "label": "Background Image",
          "description": "Select a background image for the quote",
          "configUrl": "/content/dam/config/image/asset-selector.json",
          "multi": false
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "backgroundImageMimeType"
        },      
        {
          "component": "select",
          "valueType": "string",
          "name": "backgroundImagePreset",
          "value": "",
          "label": "Background Image Preset",
          "description": "Select an image preset from the available preset renditions",
          "options": [
            { "name": "None", "value": "" },
            { "name": "Feature", "value": "Feature" },
            { "name": "Hero", "value": "Hero" },
            { "name": "Responsive", "value": "Responsive" },
            { "name": "Square", "value": "Square" },
            { "name": "Tall", "value": "Tall" },
            { "name": "VideoThumbnail", "value": "VideoThumbnail" }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "backgroundImageModifiers",
          "label": "Background Image Modifiers",
          "description": "Specify additional image modifier parameters"
        },
         {
          "component": "text",
          "valueType": "string",
          "name": "backgroundImageAlt",
          "value": "",
          "label": "Background Image Alt Text",
          "description": "Provide alt text for the background image"
        },
        {
          "component": "tab",
          "label": "Styles",
          "name": "styles"
        },
        {
          "component": "ngaem:dynamic-picklist",
          "name": "classes_customDynamicClass",
          "value": "",
          "label": "Select Block Styles",
          "valueType": "string",
          "sourceAEMNodeName": "quote-picklist-config",
          "valueSeperator": ","
        },
        {
          "...": "../../models/_common-properties.json#/common-prop"
        }
      ]
    }
  ],
  "filters": []
}

{
  "definitions": [
    {
      "title": "Cta",
      "id": "cta",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Cta",
              "model": "cta",
              "link": "/link",
              "linkText": "Button",
              "linkAriaLabel": "",
              "ctaTarget": "_self",
              "iconVariation": "none",
              "iconFont": "",
              "iconImage": "",
              "ariaHidden": false,
              "iconPosition": "after",
              "classes": "default-cta",
              "language": "none",
              "blockId": ""
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "cta",
      "fields": [
        {
          "component": "tab",
          "label": "Overview",
          "name": "overview"
        },
        {
          "component": "text",
          "name": "linkText",
          "label": "Button Text"
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "Target"
        },
        {
          "component": "text",
          "name": "aria-label",
          "label": "ARIA Label",
          "valueType": "string",
          "attribute": "data-aria-label"
        },
        {
          "component": "select",
          "label": "Click Behavior",
          "name": "ctaTarget",
          "value": "_self",
          "valueType": "string",
          "options": [
            {
              "name": "Same Tab",
              "value": "_self"
            },
            {
              "name": "New Tab",
              "value": "_blank"
            }
          ]
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "iconVariation",
          "value": "none",
          "label": "Icon Type",
          "description": "Icon type for the button",
          "options": [
            {
              "name": "None",
              "value": "none"
            },
            {
              "name": "Icon Font",
              "value": "icon-font"
            },
            {
              "name": "Image",
              "value": "image"
            }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "iconFont",
          "value": "",
          "label": "Button Font Icon",
          "description": "Font icon name for button",
          "condition": {
            "===": [
              {
                "var": "iconVariation"
              },
              "icon-font"
            ]
          }
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "iconImage",
          "label": "Button Image Icon",
          "description": "Image icon for button",
          "multi": false,
          "condition": {
            "===": [
              {
                "var": "iconVariation"
              },
              "image"
            ]
          }
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "iconPosition",
          "value": "after",
          "label": "Icon Position",
          "description": "Select whether the icon is placed before your button text or after your button text",
          "options": [
            {
              "name": "Before",
              "value": "before"
            },
            {
              "name": "After",
              "value": "after"
            }
          ],
          "condition": {
            "in": [
              {
                "var": "iconVariation"
              },
              [
                "icon-font",
                "image"
              ]
            ]
          }
        },
        {
          "component": "boolean",
          "label": "Prevent screen readers from announcing this CTA",
          "name": "ariaHidden",
          "value": false,
          "valueType": "boolean"
        },

        {
          "component": "tab",
          "label": "Styles",
          "name": "styles"
        },
        {
          "component": "ngaem:dynamic-picklist",
          "name": "classes_customDynamicClass",
          "value": "",
          "label": "Select Block Styles",
          "valueType": "string",
          "sourceAEMNodeName": "cta-picklist-config",
          "valueSeperator": ","
        },
        {
          "...": "../../models/_common-properties.json#/common-prop"
        }
      ]
    }
  ],
  "filters": []
}

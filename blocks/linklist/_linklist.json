{
  "definitions": [
    {
      "title": "LinkList",
      "id": "linklist",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "LinkList",
              "model": "linklist",
              "filter": "linklist",
              "linkSource": "custom",
              "variant": "standard",
              "layout": "single-column",
              "orderBy": "content-tree",
              "sortOrder": "asc",
              "childDepth": 1,
              "maxItems": 25
            }
          }
        }
      }
    },
    {
      "title": "LinkList Item",
      "id": "linklist-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "LinkList Item",
              "model": "linklist-item",
              "classes": "linklist-item",
              "linkText": "New Link",
              "iconType": "none",
              "openInNewTab": false,
              "cookieConsentLink": false,
              "enableConfirmationModal": false,
              "confirmationModalType": "standard",
              "iconPosition": "before"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "linklist",
      "fields": [
        {
          "component": "tab",
          "label": "Overview",
          "name": "tab-overview-linklist"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "id",
          "label": "Id",
          "value": "",
          "description": "Unique anchor ID used for deep-linking to this block."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "customClass",
          "label": "Custom Class",
          "value": "",
          "description": "CSS class name(s) for the component wrapper."
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "variant",
          "label": "Variant",
          "value": "standard",
          "description": "Structural and visual variant of the link list.",
          "options": [
            {
              "name": "Standard",
              "value": "standard"
            },
            {
              "name": "Rows with Arrows",
              "value": "rows-with-arrows"
            },
            {
              "name": "Icons",
              "value": "icons"
            },
            {
              "name": "Footer - primary",
              "value": "footer-primary"
            },
            {
              "name": "Footer - legal",
              "value": "footer-legal"
            },
            {
              "name": "Detailed list",
              "value": "detailed-list"
            },
            {
              "name": "Carousel",
              "value": "carousel"
            }
          ]
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "linkSource",
          "label": "Link Source",
          "value": "custom",
          "description": "Child Pages: auto-list from site index. Icons / Custom: add Link List Item blocks.",
          "options": [
            {
              "name": "Child Pages",
              "value": "child-pages"
            },
            {
              "name": "Icons",
              "value": "icons"
            },
            {
              "name": "Custom",
              "value": "custom"
            }
          ]
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "parentPage",
          "label": "Parent Page",
          "value": "",
          "description": "Root page path; child links are resolved from the site index under this path.",
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "number",
          "valueType": "number",
          "name": "childDepth",
          "label": "Child Depth",
          "value": 1,
          "description": "How many levels of descendants to include (1 = direct children only).",
          "validation": {
            "numberMin": 1,
            "numberMax": 10
          },
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "excludeCurrentPage",
          "label": "Exclude Current Page",
          "value": true,
          "description": "Omit the active page from the generated list.",
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "enableDescription",
          "label": "Enable Description",
          "value": false,
          "description": "Show page description below each link (from index metadata).",
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "enableTags",
          "label": "Enable Tags",
          "value": false,
          "description": "Display tags from the index when available.",
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "enableSubtitle",
          "label": "Enable Subtitle",
          "value": false,
          "description": "Show subtitle field from the index when available.",
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "enableDate",
          "label": "Enable Date",
          "value": false,
          "description": "Show published or last modified date from the index.",
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "orderBy",
          "label": "Order By",
          "value": "content-tree",
          "description": "Sort field for generated links.",
          "options": [
            {
              "name": "Content Tree",
              "value": "content-tree"
            },
            {
              "name": "Title",
              "value": "title"
            },
            {
              "name": "Last Modified",
              "value": "last-modified"
            },
            {
              "name": "Published",
              "value": "published"
            }
          ],
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "sortOrder",
          "label": "Sort Order",
          "value": "asc",
          "options": [
            {
              "name": "Ascending",
              "value": "asc"
            },
            {
              "name": "Descending",
              "value": "desc"
            }
          ],
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "number",
          "valueType": "number",
          "name": "maxItems",
          "label": "Max Items",
          "value": 25,
          "description": "Maximum number of links to output.",
          "validation": {
            "numberMin": 1,
            "numberMax": 500
          },
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "layout",
          "label": "Layout",
          "value": "single-column",
          "description": "Grid layout for list items.",
          "options": [
            {
              "name": "Single Column",
              "value": "single-column"
            },
            {
              "name": "Two Columns \u2013 stack on mobile",
              "value": "two-columns-stack"
            },
            {
              "name": "Two columns \u2013 do not stack on mobile",
              "value": "two-columns-nostack"
            }
          ],
          "condition": {
            "===": [
              {
                "var": "linkSource"
              },
              "child-pages"
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "fontIcon",
          "label": "Icon",
          "value": "",
          "description": "Icon applied to every link when Variant is Icons. Works for all link sources \u2014 the only icon option when using Child Pages.",
          "condition": {
            "or": [
              {
                "===": [
                  {
                    "var": "variant"
                  },
                  "icons"
                ]
              },
              {
                "===": [
                  {
                    "var": "linkSource"
                  },
                  "child-pages"
                ]
              }
            ]
          }
        },
        {
          "component": "tab",
          "label": "Accessibility",
          "name": "tab-accessibility-linklist"
        },
        {
          "...": "../../models/_language.json#/language-field"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "ariaLabel",
          "label": "ARIA Label",
          "value": "",
          "description": "Accessible name for the link list landmark (nav)."
        }
      ]
    },
    {
      "id": "linklist-item",
      "fields": [
        {
          "component": "tab",
          "label": "Overview",
          "name": "tab-overview-linklist-item"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "id",
          "label": "Id",
          "value": "",
          "description": "Unique anchor ID for this list item."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "customClass",
          "label": "Custom Class",
          "value": "",
          "description": "CSS class name(s) on the item container."
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "cookieConsentLink",
          "label": "Cookie Consent Link",
          "value": false,
          "description": "When enabled, opens cookie consent instead of navigating. Link and tab fields below are ignored."
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "link",
          "label": "Link",
          "value": "",
          "description": "Destination path or external URL.",
          "condition": {
            "!": [
              {
                "var": "cookieConsentLink"
              }
            ]
          }
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "openInNewTab",
          "label": "Open in a new tab",
          "value": false,
          "description": "When enabled, opens the link target in a new browser tab/window.",
          "condition": {
            "!": [
              {
                "var": "cookieConsentLink"
              }
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "linkText",
          "label": "Link Text",
          "value": "",
          "description": "Visible label; may default to target page title when blank."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "subtitle",
          "label": "Subtitle",
          "value": "",
          "description": "Optional subtitle below or beside the link."
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description",
          "value": "",
          "valueType": "string",
          "description": "Supporting summary for the item."
        },
        {
          "component": "aem-tag",
          "valueType": "string[]",
          "name": "categoryTags",
          "label": "Category Tags",
          "value": [],
          "description": "Select taxonomy tags to categorize this item."
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "iconType",
          "label": "Icon Type",
          "value": "none",
          "description": "Chooses the icon source method for the item.",
          "options": [
            {
              "name": "None",
              "value": "none"
            },
            {
              "name": "Icon Font",
              "value": "font"
            },
            {
              "name": "Image",
              "value": "image"
            }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "fontIcon",
          "label": "Font Icon",
          "value": "",
          "description": "Name of the font icon (e.g., library glyph name); visible only when Icon Type = Icon Font.",
          "condition": {
            "===": [
              {
                "var": "iconType"
              },
              "font"
            ]
          }
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "imageIcon",
          "label": "Image Icon",
          "value": "",
          "multi": false,
          "accepts": [
            "image/*"
          ],
          "condition": {
            "===": [
              {
                "var": "iconType"
              },
              "image"
            ]
          }
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "iconPosition",
          "label": "Icon Position",
          "value": "before",
          "options": [
            {
              "name": "Before",
              "value": "before"
            },
            {
              "name": "After",
              "value": "after"
            }
          ],
          "condition": {
            "in": [
              {
                "var": "iconType"
              },
              [
                "font",
                "image"
              ]
            ]
          }
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "iconLink",
          "label": "Icon Link",
          "value": "",
          "description": "Optional separate target when clicking the icon.",
          "condition": {
            "in": [
              {
                "var": "iconType"
              },
              [
                "font",
                "image"
              ]
            ]
          }
        },
        {
          "component": "boolean",
          "valueType": "boolean",
          "name": "enableConfirmationModal",
          "label": "Enable Confirmation Modal",
          "value": false,
          "description": "Prompts users with a modal before navigation (useful for warnings or external links)."
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "confirmationModalType",
          "label": "Type of confirmation modal",
          "value": "standard",
          "description": "Exit modal applies a distinct dialog style.",
          "options": [
            {
              "name": "Standard",
              "value": "standard"
            },
            {
              "name": "Exit modal",
              "value": "exit-modal"
            }
          ],
          "condition": {
            "===": [
              {
                "var": "enableConfirmationModal"
              },
              true
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "modalId",
          "label": "Modal ID / Path",
          "value": "",
          "description": "Path to a modal fragment (e.g. /modals/warning).",
          "condition": {
            "===": [
              {
                "var": "enableConfirmationModal"
              },
              true
            ]
          }
        },
        {
          "component": "tab",
          "label": "Accessibility",
          "name": "tab-accessibility-linklist-item"
        },
        {
          "...": "../../models/_language.json#/language-field"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "ariaLabel",
          "label": "Aria Label",
          "value": "",
          "description": "Accessible name when link text is ambiguous."
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "linklist",
      "components": [
        "linklist-item"
      ]
    },
    {
      "id": "linklist-child-pages",
      "components": []
    }
  ]
}
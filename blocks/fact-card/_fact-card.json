            { "name": "Default", "value": "" },
            { "name": "Medium (Light Blue)", "value": "medium-theme" },
            { "name": "Dark (Navy)", "value": "dark-theme" }
          ]
        },
        {
          "component": "select",
          "name": "imagePreset",
          "label": "Image Preset",
          "description": "Choose a predefined image rendition or crop configuration.",

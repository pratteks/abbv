            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "fact-card",
      "fields": [
        {
          "component": "tab",
          "label": "Overview",
          "name": "overview"
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "contentFragment",
          "label": "Content Fragment",
          "description": "Select a content fragment to source data for the card (eyebrow, data point, suffix, description, image)."
        },
        {
          "component": "boolean",
          "name": "hideImage",
          "label": "Hide Image",
          "description": "Toggle to remove the image from the card layout.",
          "value": false,
          "valueType": "boolean"
        },
        {
          "component": "select",
          "name": "imagePreset",
          "label": "Image Preset",
          "description": "Choose a predefined image rendition or crop configuration.",
          "valueType": "string",
          "value": "",
          "options": [
            { "name": "None", "value": "" },
            { "name": "Feature", "value": "Feature" },
            { "name": "Hero", "value": "Hero" },
            { "name": "Responsive", "value": "Responsive" },
            { "name": "Square", "value": "Square" },
            { "name": "Tall", "value": "Tall" },
            { "name": "VideoThumbnail", "value": "VideoThumbnail" }
          ],
          "condition": {
            "===": [{ "var": "hideImage" }, false]
          }
        },
        {
          "component": "text",
          "name": "imageModifiers",
          "label": "Image Modifiers",
          "description": "Apply additional transformation parameters (e.g., width, quality) supported by the image service.",
          "value": "",
          "valueType": "string",
          "condition": {
            "===": [{ "var": "hideImage" }, false]
          }
        },
        {
          "component": "tab",
          "label": "Styles",
          "name": "styles"
        },
        {
          "component": "ngaem:dynamic-picklist",
          "name": "classes_customDynamicClass",
          "value": "",
          "label": "Select Block Styles",
          "valueType": "string",
          "sourceAEMNodeName": "fact-card-picklist-config",
          "valueSeperator": ","
        },
        {
           "...": "../../models/_common-properties.json#/common-prop"
        }
      ]
    }
  ],
  "filters": []
}

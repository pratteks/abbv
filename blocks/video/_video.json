{
  "definitions": [
    {
      "title": "Video",
      "id": "video",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Video",
              "model": "video",
              "filter": "video",
              "language": "none",
              "blockId": ""
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "video",
      "fields": [
        {
          "component": "tab",
          "label": "Overview",
          "name": "overview"
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "uri",
          "label": "Video"
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "valueType": "string",
          "name": "placeholderImage",
          "label": "Poster Image",
          "configUrl": "/content/dam/config/image/asset-selector.json",
          "multi": false
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "placeholderImageMimeType"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "placeholderAlt",
          "value": "",
          "label": "Poster Alt Text",
          "description": "Provide alt text for the poster image for accessibility."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "overlayTitle",
          "value": "",
          "label": "Overlay Title",
          "description": "Title displayed on top of the video before the user clicks play."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "overlayDescription",
          "value": "",
          "label": "Overlay Description",
          "description": "Description displayed on top of the video before the user clicks play."
        },
        {
          "name": "overlayBtnText",
          "label": "Overlay Button Text",
          "component": "text",
          "description": "Defines the button text displayed on the video overlay before playback."
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "videoContentLayout",
          "value": "none",
          "label": "Content Position",
          "options": [
            {
              "name": "None (overlay)",
              "value": "none"
            },
            {
              "name": "Bottom",
              "value": "bottom"
            },
            {
              "name": "Left",
              "value": "left"
            },
            {
              "name": "Right",
              "value": "right"
            }
          ]
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "classes_overlayColor",
          "value": "video-overlay-navy",
          "label": "Color Overlay",
          "options": [
            {
              "name": "Navy Overlay",
              "value": "video-overlay-navy"
            },
            {
              "name": "Gray Overlay",
              "value": "video-overlay-gray"
            },
            {
              "name": "Purple Overlay",
              "value": "video-overlay-purple"
            }
          ],
          "description": "Provide a solid background color that overlays the video before playback begins."
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "classes_overlayBtnStyle",
          "value": "video-btn-outline",
          "label": "Overlay Button Style",
          "options": [
            {
              "name": "Outline",
              "value": "video-btn-outline"
            },
            {
              "name": "Solid",
              "value": "video-btn-solid"
            },
            {
              "name": "Ghost",
              "value": "video-btn-ghost"
            }
          ]
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "overlayButtonIconType",
          "value": "icon-font",
          "label": "Overlay Button Icon Type",
          "description": "Select the icon type used in the overlay button",
          "options": [
            {
              "name": "Icon Font",
              "value": "icon-font"
            },
            {
              "name": "Image",
              "value": "image"
            }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "overlayButtonFontIcon",
          "value": "play",
          "label": "Overlay Button Font Icon",
          "description": "Define the icon font name for the button.",
          "condition": {
            "===": [
              {
                "var": "overlayButtonIconType"
              },
              "icon-font"
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "projectNumber",
          "value": "",
          "label": "Project Number",
          "description": "Enter the project reference number if applicable."
        },
        {
          "component": "tab",
          "label": "Video Features",
          "name": "Videofeatures"
        },
        {
          "component": "boolean",
          "name": "enableAutoplay",
          "label": "Enable Autoplay",
          "value": false,
          "valueType": "boolean",
          "description": "If selected this video will auto play when it comes into the view of the user."
        },
        {
          "component": "boolean",
          "name": "enableCaptions",
          "label": "Enable Captions",
          "value": false,
          "valueType": "boolean",
          "description": "If selected captions will be displayed"
        },
        {
          "component": "boolean",
          "name": "enablePlayerControls",
          "label": "Enable Player Controls",
          "value": true,
          "valueType": "boolean",
          "description": "If selected a video toolbar will be available to the user (play, pause, etc)"
        },
        {
          "component": "boolean",
          "name": "enableFullscreen",
          "label": "Allow Fullscreen",
          "value": true,
          "valueType": "boolean"
        },
        {
          "component": "tab",
          "label": "Styles",
          "name": "styles"
        },
        {
          "component": "ngaem:dynamic-picklist",
          "name": "classes_customDynamicClass",
          "value": "",
          "label": "Select Block Styles",
          "valueType": "string",
          "sourceAEMNodeName": "video-picklist-config",
          "valueSeperator": ","
        },
        {
          "...": "../../models/_common-properties.json#/common-prop"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "video",
      "components": []
    }
  ]
}

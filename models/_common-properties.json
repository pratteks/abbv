    {
      "component": "text",
      "valueType": "string",
      "name": "classes_commonCustomClass",
      "label": "Custom Class",
      "description": "Custom CSS class to apply to this block"
    },
    {
      "...": "_language.json#/language-field"
    }
  ]
}